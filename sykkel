            { org: "bk", dept: "Plan og utredning", name: "Thomas", role: "overlapp i sentrum og sandviken", relations: ["Sentrumsprosjekter (overlapp)"], date: "februar-2025", note: "" },
            { org: "bk", dept: "Bylogistikk og mobilitet", name: "Einar Grieg", role: "Bysykkel, langsiktig og strategisk, Kampanjer", relations: ["Bysykkel & Kampanje"], date: "aug-2025", note: "" },
            { org: "bk", dept: "Klima og risiko", name: "Jøran Buwalda", role: "klimabudsjett, strategi og analyse knytt til energiomstilling", relations: ["Transport"], date: "Løpende", note: "" },

            // MILJØLØFTET
            { org: "ml", dept: "Representantskapet", name: "Representantskapet", role: "Vegsjef, byråder, ordførere, baneNor, etc", relations: ["Sekretariat & Styring"], date: "Løpende", note: "" },
            { org: "ml", dept: "Sekretariat", name: "Kari Gasemyr", role: "sekreatsleder", relations: ["Sekretariat & Styring"], date: "Løpende", note: "" },
            { org: "ml", dept: "Kommunikasjon", name: "Anders Kjetland", role: "Kommunikasjon", relations: ["Kommunikasjon & Nabokontakt"], date: "12-11-2025", note: "" },
            { org: "ml", dept: "Rådgivere", name: "Erlend Bjerke Otterå", role: "rådgiver", relations: ["Utredning & Planlegging"], date: "Løpende", note: "" },
            { org: "ml", dept: "Rådgivere", name: "Kristina Vikesund", role: "rådgiver", relations: ["Utredning & Planlegging"], date: "Løpende", note: "" },

            // ANDRE
            { org: "andre", dept: "Rexir", name: "Helge Hopen (Rexir)", role: "trafikkplanlegger (Rexir / Byarena)", relations: ["Rexir/Trafikkplanlegging (Ekstern)"], date: "Løpende", note: "" },
            { org: "andre", dept: "Rexir", name: "Kari Sørebo (Rexir)", role: "Rexir med byarena", relations: ["Store Prosjekter (Byarena)"], date: "Løpende", note: "" },
            { org: "andre", dept: "Frivillige", name: "Syklistforeningen", role: "Reidar, Arild, Peter, Andreas, Eivind m.fl.", relations: ["Brukerrepresentasjon"], date: "Nov 2025", note: "" },
            { org: "andre", dept: "Frivillige", name: "Critical Mass", role: "Sarah, Georgia, Hannes", relations: ["Øke sykkelinteressen"], date: "Løpende", note: "" }
        ];

        const orgNames = {
            vfk: "Vestland Fylkeskommune",
            svv: "Statens vegvesen",
            bk: "Bergen kommune",
            ml: "Miljøløftet",
            andre: "Andre aktører"
        };

        const relColors = {
            "Veiforvaltning & Geodata": "r-blaa",
            "Veiforvaltning & geodata": "r-blaa",
            "Delstrekning 4 / utbygging": "r-lilla",
            "Delstrekning 4/Utbygging": "r-lilla",
            "Mobilitet & kollektivtrafikk": "r-gronn",
            "Mobilitet": "r-gronn",
            "Utredning & planlegging": "r-lilla",
            "Utredning & Planlegging": "r-lilla",
            "Trafikkteknikk & skilt": "r-lilla",
            "Telling & reisevaner (data)": "r-gronn",
            "Gå-/Bybaneplanlegging": "r-lilla",
            "Transportforvaltning & byvekst": "r-blaa",
            "Store Prosjekter (Tunnel/Byarena)": "r-lilla",
            "Store Prosjekter (Byarena)": "r-lilla",
            "Kommunikasjon & Nabokontakt": "r-gronn",
            "Sykkelstamvei (Del 6)": "r-lilla",
            "Arbeidsvarsling & sikring": "r-blaa",
            "Leder Task Force Sykkel (Bindeledd)": "r-lilla",
            "Sentrumsprosjekter (Koengen-Sandviken)": "r-lilla",
            "Sentrumsprosjekter": "r-lilla",
            "Sentrumsprosjekter (overlapp)": "r-lilla",
            "Bysykkel & Kampanje": "r-gronn",
            "Transport": "r-blaa",
            "Sekretariat & Styring": "r-rosa",
            "Rexir/Trafikkplanlegging (Ekstern)": "r-blaa",
            "Brukerrepresentasjon": "r-blaa",
            "Øke sykkelinteressen": "r-gronn"
        };

        let currentOrg = 'all';
        let currentView = 'cards';
        let searchActive = false;

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('totalPersons').textContent = persons.length;
            renderCards();
            renderTable();
            renderOrgChart();
            displayAIData();
        });

        function renderCards() {
            const container = document.getElementById('personCards');
            container.innerHTML = '';
            
            const filtered = currentOrg === 'all' ? persons : persons.filter(p => p.org === currentOrg);
            
            filtered.forEach(person => {
                const card = document.createElement('div');
                card.className = `person-card org-${person.org}`;
                card.setAttribute('data-org', person.org);
                card.setAttribute('data-name', person.name.toLowerCase());
                card.setAttribute('data-search', `${person.name} ${person.role} ${person.dept} ${person.date} ${person.relations.join(' ')}`.toLowerCase());
                
                const tagsHTML = person.relations.map(rel => 
                    `<span class="tag ${relColors[rel] || 'r-blaa'}" onclick="filterByRelation('${rel}')">${rel}</span>`
                ).join('');
                
                const noteHTML = person.note ? `<div class="person-note">⚠️ ${person.note}</div>` : '';
                
                card.innerHTML = `
                    <div class="person-header">
                        <div class="person-name">${person.name}</div>
                        <div class="person-dept">${person.dept}</div>
                        <div class="person-org">${orgNames[person.org]}</div>
                    </div>
                    <div class="person-role">${person.role}</div>
                    <div class="person-tags">${tagsHTML}</div>
                    <div class="person-date">
                        📅 Sist møtt: <span class="date-highlight">${person.date}</span>
                    </div>
                    ${noteHTML}
                `;
                
                container.appendChild(card);
            });
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';
            
            const grouped = {};
            persons.forEach(p => {
                if (!grouped[p.org]) grouped[p.org] = {};
                if (!grouped[p.org][p.dept]) grouped[p.org][p.dept] = [];
                grouped[p.org][p.dept].push(p);
            });
            
            Object.keys(grouped).forEach(org => {
                const orgRow = document.createElement('tr');
                orgRow.className = `org-header-row org-${org}`;
                orgRow.setAttribute('data-org', org);
                orgRow.innerHTML = `<td colspan="5">▼ ${orgNames[org].toUpperCase()}</td>`;
                orgRow.onclick = () => toggleOrgRows(org);
                tbody.appendChild(orgRow);
                
                Object.keys(grouped[org]).forEach(dept => {
                    const deptRow = document.createElement('tr');
                    deptRow.className = `dept-header-row org-${org}-row`;
                    deptRow.setAttribute('data-org', org);
                    deptRow.innerHTML = `<td colspan="5">${dept}</td>`;
                    tbody.appendChild(deptRow);
                    
                    grouped[org][dept].forEach(person => {
                        const tagsHTML = person.relations.map(rel => 
                            `<span class="tag ${relColors[rel] || 'r-blaa'}" onclick="filterByRelation('${rel}')" style="cursor: pointer;">${rel}</span>`
                        ).join('');
                        
                        const row = document.createElement('tr');
                        row.className = `org-${org}-row person-row`;
                        row.setAttribute('data-org', org);
                        row.setAttribute('data-name', person.name.toLowerCase());
                        row.setAttribute('data-search', `${person.name} ${person.role} ${person.dept} ${person.date} ${person.relations.join(' ')}`.toLowerCase());
                        row.innerHTML = `
                            <td>${person.dept}</td>
                            <td><strong>${person.name}</strong></td>
                            <td>${person.role}${person.note ? `<div class="person-note" style="margin-top:0.5rem">⚠️ ${person.note}</div>` : ''}</td>
                            <td>${tagsHTML}</td>
                            <td>${person.date}</td>
                        `;
                        tbody.appendChild(row);
                    });
                });
            });
        }

        function renderOrgChart() {
            const container = document.getElementById('orgChartContainer');
            container.innerHTML = '';
            
            // Group by org and dept
            const orgStructure = {
                vfk: {
                    "Infrastruktur og veg": [],
                    "Mobilitet og kollektivtrafikk": [],
                    "Fageksperter": []
                },
                svv: {
                    "Transportforvaltning": [],
                    "Utbygging": [],
                    "Transport og samfunn": []
                },
                bk: {
                    "Mobilitetsseksjonen": [],
                    "Plan og utredning": [],
                    "Bylogistikk og mobilitet": [],
                    "Klima og risiko": []
                },
                ml: {
                    "Representantskapet": [],
                    "Sekretariat": [],
                    "Kommunikasjon": [],
                    "Rådgivere": []
                },
                andre: {
                    "Rexir": [],
                    "Frivillige": []
                }
            };
            
            persons.forEach(p => {
                if (orgStructure[p.org] && orgStructure[p.org][p.dept]) {
                    orgStructure[p.org][p.dept].push(p);
                }
            });
            
            // Render each org
            Object.keys(orgStructure).forEach(org => {
                const orgBox = document.createElement('div');
                orgBox.className = 'org-box';
                
                let html = `<div class="org-header org-${org}-header">${orgNames[org]}</div>`;
                html += `<div class="dept-columns">`;
                
                Object.keys(orgStructure[org]).forEach(dept => {
                    if (orgStructure[org][dept].length > 0) {
                        html += `<div class="dept-section">`;
                        html += `<div class="dept-title">${dept}</div>`;
                        html += `<div class="person-boxes">`;
                        
                        orgStructure[org][dept].forEach(person => {
                            html += `<div class="person-box" onclick="scrollToPerson('${person.name}')">${person.name}</div>`;
                        });
                        
                        html += `</div></div>`;
                    }
                });
                
                html += `</div>`;
                orgBox.innerHTML = html;
                container.appendChild(orgBox);
            });
        }

        function scrollToPerson(name) {
            // Switch to cards view
            switchView('cards');
            
            // Wait for view to switch
            setTimeout(() => {
                // Clear any existing search
                resetSearch();
                
                // Find and highlight the person card
                const cards = document.querySelectorAll('.person-card');
                cards.forEach(card => {
                    if (card.getAttribute('data-name') === name.toLowerCase()) {
                        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        
                        // Add temporary highlight
                        card.style.boxShadow = '0 0 0 4px var(--accent)';
                        setTimeout(() => {
                            card.style.boxShadow = '';
                        }, 2000);
                    }
                });
            }, 100);
        }

        function toggleOrgRows(org) {
            const rows = document.querySelectorAll(`.org-${org}-row`);
            rows.forEach(row => row.classList.toggle('hidden'));
        }

        function switchView(view) {
            currentView = view;
            
            document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
            document.querySelector(`.tab[data-view="${view}"]`).classList.add('active');
            
            document.getElementById('cardsView').classList.toggle('hidden', view !== 'cards');
            document.getElementById('tableView').classList.toggle('hidden', view !== 'table');
            document.getElementById('orgchartView').classList.toggle('hidden', view !== 'orgchart');
        }

        function filterByOrg(org) {
            currentOrg = org;
            
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelector(`.filter-btn[data-org="${org}"]`).classList.add('active');
            
            if (currentView === 'cards') {
                renderCards();
                if (searchActive) {
                    performSearch();
                }
            } else if (currentView === 'table') {
                // Filter table rows
                const allRows = document.querySelectorAll('#tableBody tr');
                allRows.forEach(row => {
                    const rowOrg = row.getAttribute('data-org');
                    if (org === 'all' || rowOrg === org) {
                        row.classList.remove('hidden');
                    } else {
                        row.classList.add('hidden');
                    }
                });
            }
        }

        function filterByRelation(relation) {
            const searchInput = document.getElementById('searchInput');
            searchInput.value = relation;
            performSearch();
            
            // Scroll to top to see results
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function performSearch() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            searchActive = query.length > 0;
            
            if (currentView === 'cards') {
                const cards = document.querySelectorAll('.person-card');
                let matchedCards = [];
                
                cards.forEach(card => {
                    const searchText = card.getAttribute('data-search');
                    if (searchText.includes(query)) {
                        card.style.display = 'block';
                        card.style.order = '0';
                        matchedCards.push(card);
                    } else {
                        card.style.display = query === '' ? 'block' : 'none';
                        card.style.order = '999';
                    }
                });
                
                // Move matched cards to top
                if (matchedCards.length > 0 && query !== '') {
                    const container = document.getElementById('personCards');
                    matchedCards.forEach(card => container.prepend(card));
                }
            } else if (currentView === 'table') {
                const rows = document.querySelectorAll('#tableBody .person-row');
                rows.forEach(row => {
                    const searchText = row.getAttribute('data-search') || '';
                    row.style.display = searchText.includes(query) ? '' : 'none';
                });
            }
        }

        function resetSearch() {
            document.getElementById('searchInput').value = '';
            searchActive = false;
            performSearch();
        }

        function exportJSON() {
            const dataStr = JSON.stringify(persons, null, 2);
            const blob = new Blob([dataStr], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'sykkel-bergen-data.json';
            a.click();
        }

        function exportCSV() {
            const headers = ['Organisasjon', 'Avdeling', 'Navn', 'Rolle', 'Relasjoner', 'Sist møtt', 'Notat'];
            const rows = persons.map(p => [
                orgNames[p.org],
                p.dept,
                p.name,
                p.role,
                p.relations.join('; '),
                p.date,
                p.note
            ]);
            
            const csv = [headers, ...rows].map(row => row.map(cell => `"${cell}"`).join(',')).join('\n');
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'sykkel-bergen-data.csv';
            a.click();
        }

        function displayAIData() {
            const fullDataset = {
                meta: { ver: 2.1, last_update: "2026-03-17", author: "Claude Sonnet 4.5" },
                total_persons: persons.length,
                organizations: {
                    vfk: persons.filter(p => p.org === 'vfk').length,
                    svv: persons.filter(p => p.org === 'svv').length,
                    bk: persons.filter(p => p.org === 'bk').length,
                    ml: persons.filter(p => p.org === 'ml').length,
                    andre: persons.filter(p => p.org === 'andre').length
                },
                persons: persons
            };
            document.getElementById('aiData').textContent = JSON.stringify(fullDataset, null, 2);
        }
    </script>
