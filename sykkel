            { org: "bk", dept: "Mobilitetsseksjonen", name: "Marie Bell", role: "Leder task force Sykkel, Fagleder sykkel, Bindeledd veieiere", relations: ["Leder Task Force Sykkel (Bindeledd)"], date: "12-11-2025", note: "Hovedansvarlig for alle sykkelprosjekter i kommunen. Ansvar for rekkefølgekrav og byggesak. Ringe henne om det er noe ved bygging." },
            { org: "bk", dept: "Plan og utredning", name: "Eskil Bakke", role: "Koengen–Festplassen–Sandviken sykehus", relations: ["Sentrumsprosjekter (Koengen-Sandviken)"], date: "12-11-2025", note: "" },
            { org: "bk", dept: "Plan og utredning", name: "Håkon", role: "sykkeldelen av prosjekte", relations: ["Sentrumsprosjekter"], date: "aug-2025", note: "" },
