            { org: "svv", dept: "Transportforvaltning", name: "Astrid", role: "Gastrategi, bybaneplanlegging, planforvalter", relations: ["Gå-/Bybaneplanlegging", "Utredning & planlegging"], date: "Løpende", note: "" },
            { org: "svv", dept: "Transportforvaltning", name: "Frode", role: "transportforvaltning, oppfølging av eksterne, riksveinett, byvekst", relations: ["Transportforvaltning & byvekst"], date: "Løpende", note: "" },
            { org: "svv", dept: "Transportforvaltning", name: "Kjell Erik", role: "Tunnell bak bryggen, bybane vest, byarena", relations: ["Store Prosjekter (Tunnel/Byarena)"], date: "Løpende", note: "" },
            { org: "svv", dept: "Utbygging", name: "Hanne Anette Norheim", role: "Nabokontakt byvekst", relations: ["Kommunikasjon & Nabokontakt"], date: "juni-2025", note: "" },
            { org: "svv", dept: "Utbygging", name: "Hilde Kallekleiv", role: "Planleder gang og sykkel vagsbotn-klaevneset", relations: ["Utredning & planlegging"], date: "juni-2025", note: "" },
            { org: "svv", dept: "Utbygging", name: "Helene Dahle", role: "delstrekning 2 og 4", relations: ["Delstrekning 4/Utbygging"], date: "juni-2025", note: "" },
            { org: "svv", dept: "Utbygging", name: "Inge-Andre", role: "delprosjektleder utbygging, Nordhordaland", relations: ["Delstrekning 4/Utbygging"], date: "juni-2024", note: "" },
            { org: "svv", dept: "Utbygging", name: "Caroline", role: "kommunikasjonsrådgiver sykkelstamvei (del 6)", relations: ["Sykkelstamvei (Del 6)", "Kommunikasjon & Nabokontakt"], date: "juni-2024", note: "" },
            { org: "svv", dept: "Transport og samfunn", name: "Olav B. Aga", role: "Godkjenning arbeidsvarsling og sikring", relations: ["Arbeidsvarsling & sikring"], date: "Løpende", note: "" },

